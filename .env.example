# FastAPI
APP_NAME=Kinova
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Kinoheld GraphQL API
KINOHELD_GRAPHQL_URL=https://graph.kinoheld.de/graphql/v1/query
KINOHELD_REQUEST_TIMEOUT=30.0
KINOHELD_POOL_LIMITS=10

# Optional: affiliate key for commissionable links
KINOHELD_AFFILIATE_KEY=

# Kinoheld cache / sync settings
KINOHELD_SYNC_INTERVAL_SECONDS=600
KINOHELD_SYNC_CINEMA_IDS=
KINOHELD_SYNC_SHOW_DAYS=7
KINOHELD_SYNC_MOVIE_LIMIT=100
KINOHELD_SYNC_CINEMA_LIMIT=100

# LLM provider for natural-language search (OpenAI-compatible API)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_REQUEST_TIMEOUT=60.0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0
LLM_FALLBACK_SEARCH_ENABLED=true
