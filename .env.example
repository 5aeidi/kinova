# FastAPI
APP_NAME=Kinova
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Kinoheld GraphQL API
KINOHELD_GRAPHQL_URL=https://graph.kinoheld.de/graphql/v1/query
KINOHELD_REQUEST_TIMEOUT=30.0
KINOHELD_POOL_LIMITS=10

# Optional: affiliate key for commissionable links
KINOHELD_AFFILIATE_KEY=

# Cinetixx legacy showtime endpoint
CINETIXX_SHOW_INFO_URL=https://api.cinetixx.de/Services/CinetixxService.asmx/GetShowInfoV6
CINETIXX_CINEMA_SEARCH_URL=https://booking.cinetixx.de/api/cinemas/
CINETIXX_REQUEST_TIMEOUT=30.0
CINETIXX_POOL_LIMITS=10
CINETIXX_SYNC_INTERVAL_SECONDS=3600
# Comma-separated values are accepted; leave blank to disable startup seeding.
# Optional additional mandator IDs. Discovery runs automatically from the public cinema index.
# Example: CINETIXX_SYNC_MANDATOR_IDS=1627457285,42
CINETIXX_SYNC_MANDATOR_IDS=
# Optional additional cinema searches, useful only if an operator is missing from the index.
# Example: CINETIXX_SYNC_DISCOVERY_SEARCHES=ACUDkino
CINETIXX_SYNC_DISCOVERY_SEARCHES=
CINETIXX_DISCOVERY_PAGE_SIZE=100
CINETIXX_DISCOVERY_MAX_PAGES=100
# Optional override for public-index enumeration terms. Blank uses a-z and 0-9.
CINETIXX_DISCOVERY_TERMS=
CINETIXX_SYNC_SHOW_DAYS=7

# Kinoheld cache / sync settings
KINOHELD_SYNC_INTERVAL_SECONDS=600
# Comma-separated values are accepted; leave blank to skip show pre-fetching.
KINOHELD_SYNC_CINEMA_IDS=
KINOHELD_SYNC_SHOW_DAYS=7
KINOHELD_SYNC_MOVIE_LIMIT=100
KINOHELD_SYNC_CINEMA_LIMIT=100

# LLM provider for natural-language search (OpenAI-compatible API)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_REQUEST_TIMEOUT=60.0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0
LLM_FALLBACK_SEARCH_ENABLED=true
